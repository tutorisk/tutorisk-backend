# ─── Serveur ──────────────────────────────────────────────
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ─── Base de données PostgreSQL ──────────────────────────────
# Exemple local : postgresql://tutorisk:motdepasse@localhost:5432/tutorisk
DATABASE_URL=postgresql://user:password@localhost:5432/tutorisk

# ─── JWT (générez des chaînes aléatoires longues, ex: openssl rand -hex 64) ──
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ─── Jeton de signature vidéo (protection sans DRM) ──────────
VIDEO_SIGNING_SECRET=change_me_video_secret
VIDEO_TOKEN_TTL=10m

# ─── Stripe — renseignez vos propres clés (test ou prod) ─────
STRIPE_SECRET_KEY=sk_test_votre_cle_stripe
STRIPE_WEBHOOK_SECRET=whsec_votre_secret_webhook

# ─── Coordonnées bancaires affichées pour le paiement par virement ──
BANK_ACCOUNT_HOLDER=TutoRisk SAS
BANK_IBAN=FR76 XXXX XXXX XXXX XXXX XXXX XXX
BANK_BIC=XXXXXXXX
BANK_NAME=Votre banque

# ─── Stockage des fichiers vidéo/documents protégés ──────────
# Dossier NON exposé publiquement — accès uniquement via /stream après vérification du jeton
PROTECTED_MEDIA_DIR=/var/tutorisk/media

# ─── Stockage des images d'attestation (tampon, signature) ──
# Dossier sur disque où sont conservées les images uploadées par l'admin
# depuis l'onglet "Attestations". Par défaut : tutorisk-backend/certificate-assets
CERTIFICATE_ASSETS_DIR=

# ─── Stockage des images de bandeaux d'annonce ───────────────
# Par défaut : tutorisk-backend/banner-assets
BANNER_ASSETS_DIR=

# ─── Email (notifications : inscription, fin de formation, crédits) ──
# Si laissé vide, les emails s'affichent simplement dans le terminal au lieu
# d'être envoyés (utile en développement, sans bloquer le reste du site).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=TutoRisk <no-reply@tutorisk.com>
